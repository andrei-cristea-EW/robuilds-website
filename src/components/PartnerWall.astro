---
import { t, localePath, type Locale } from '../i18n';
import { PARTNERS } from '../data/site';
const { locale } = Astro.props as { locale: Locale };
const dict = t(locale);
---
<section id="partners" class="relative bg-[var(--color-bg-elevated)] py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mb-10 sm:mb-14 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-accent)] mb-4">{dict.partners.kicker}</p>
        <h2 class="font-display text-3xl sm:text-5xl lg:text-6xl leading-[0.95] text-white">{dict.partners.title}</h2>
      </div>
      <a href={localePath(locale, 'partnerships')} class="inline-flex items-center text-sm font-semibold text-[var(--color-accent)] hover:text-white transition-colors">
        {dict.partners.cta}
      </a>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-px bg-[var(--color-border)] border border-[var(--color-border)] rounded-sm overflow-hidden">
      {PARTNERS.map((p, i) => (
        <div class="reveal bg-[var(--color-bg)] aspect-[3/2] flex items-center justify-center p-6 sm:p-8 group hover:bg-[var(--color-bg-elevated)] transition-colors" style={`transition-delay: ${i * 50}ms`}>
          <img
            src={p.logo}
            alt={p.name}
            class="max-h-20 max-w-full w-auto object-contain grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500"
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>
  </div>
</section>
