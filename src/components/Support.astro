---
import { t, localePath, type Locale } from '../i18n';
import { SITE } from '../data/site';
const { locale } = Astro.props as { locale: Locale };
const dict = t(locale);
const items = [
  { ...dict.support.items.form230, href: SITE.form230Url, external: true, icon: 'form' },
  { ...dict.support.items.partner, href: localePath(locale, 'partnerships'), external: false, icon: 'handshake' },
  { ...dict.support.items.shop, href: localePath(locale, 'shop'), external: false, icon: 'bag' },
];
---
<section id="support" class="relative bg-[var(--color-bg-elevated)] py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mb-10 sm:mb-14 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-accent)] mb-4">{dict.support.kicker}</p>
      <h2 class="font-display text-3xl sm:text-5xl lg:text-6xl leading-[0.95] text-white sm:whitespace-nowrap">{dict.support.title}</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-4 sm:gap-6">
      {items.map((it, i) => (
        <a
          href={it.href}
          target={it.external ? '_blank' : undefined}
          rel={it.external ? 'noopener noreferrer' : undefined}
          class="reveal group relative bg-[var(--color-bg-card)] border border-[var(--color-border)] hover:border-[var(--color-accent)] rounded-sm p-6 sm:p-8 flex flex-col transition-colors"
          style={`transition-delay: ${i * 100}ms`}
        >
          <div class="mb-5 w-11 h-11 flex items-center justify-center bg-[var(--color-accent)] text-black rounded-sm">
            {it.icon === 'form' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="square"><path d="M4 4h12l4 4v12H4z"/><path d="M8 12h8M8 16h5"/></svg>
            )}
            {it.icon === 'handshake' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="square"><path d="M3 12l4-4 5 5 5-5 4 4-9 9z"/></svg>
            )}
            {it.icon === 'bag' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="square"><path d="M5 7h14l-1 14H6z"/><path d="M9 7a3 3 0 016 0"/></svg>
            )}
          </div>
          <h3 class="font-display text-xl sm:text-2xl text-white leading-tight">{it.title}</h3>
          <p class="mt-3 text-sm text-[var(--color-text)]/80 flex-1">{it.body}</p>
          <span class="mt-5 inline-flex items-center text-sm font-semibold text-[var(--color-accent)] group-hover:gap-2 transition-all">
            {it.cta} <span class="ml-1.5 group-hover:ml-2 transition-all">→</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
