---
import { t, type Locale } from '../i18n';
const { locale } = Astro.props as { locale: Locale };
const dict = t(locale);
const goals = [
  { key: 'national', ...dict.goals.items.national, image: '/images/team-podium-redbull-trophy' },
  { key: 'international', ...dict.goals.items.international, image: '/images/drift-panning-redrift-26' },
];
---
<section id="goals" class="relative bg-[var(--color-bg)] py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mb-10 sm:mb-14 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-accent)] mb-4">{dict.goals.kicker}</p>
      <h2 class="font-display text-3xl sm:text-5xl lg:text-6xl leading-[0.95] text-white">{dict.goals.title}</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-4 sm:gap-6">
      {goals.map((g, i) => (
        <article class="reveal relative aspect-[4/3] sm:aspect-[5/4] overflow-hidden rounded-sm group" style={`transition-delay: ${i * 100}ms`}>
          <picture>
            <source srcset={`${g.image}.webp`} type="image/webp" />
            <img src={`${g.image}.jpg`} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" decoding="async" />
          </picture>
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
          <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8">
            <h3 class="font-display text-xl sm:text-3xl text-white leading-tight">{g.title}</h3>
            <p class="mt-2 text-sm sm:text-base text-[var(--color-text)]/85">{g.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
