---
import { t, type Locale } from '../i18n';
const { locale } = Astro.props as { locale: Locale };
const dict = t(locale);

const offers = [
  { key: 'car', image: '/images/bmw-e46-night-side', ...dict.partnerships.offers.car },
  { key: 'suit', image: '/images/team-podium-redbull-trophy', ...dict.partnerships.offers.suit },
  { key: 'uniform', image: '/images/team-paddock-group', ...dict.partnerships.offers.uniform },
  { key: 'social', image: '/images/drift-action-pakelo-track', ...dict.partnerships.offers.social },
  { key: 'paddock', image: '/images/fans-supporters-portrait', ...dict.partnerships.offers.paddock },
];
---
<section class="relative bg-[var(--color-bg)] py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mb-10 sm:mb-14">
      <h2 class="font-display text-3xl sm:text-5xl text-white">{dict.partnerships.offers_title}</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      {offers.map((o, i) => (
        <article class="reveal group relative aspect-[4/3] overflow-hidden rounded-sm bg-[var(--color-bg-card)] border border-[var(--color-border)]" style={`transition-delay: ${i * 80}ms`}>
          <picture>
            <source srcset={`${o.image}.webp`} type="image/webp" />
            <img src={`${o.image}.jpg`} alt="" class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-60 group-hover:scale-105 transition-all duration-700" loading="lazy" decoding="async" />
          </picture>
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/70 to-black/20"></div>
          <div class="relative h-full flex flex-col justify-end p-5 sm:p-6">
            <div class="text-xs font-mono text-[var(--color-accent)] mb-2">0{i + 1}</div>
            <h3 class="font-display text-xl sm:text-2xl text-white leading-tight">{o.title}</h3>
            <p class="mt-2 text-sm text-[var(--color-text)]/85">{o.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
