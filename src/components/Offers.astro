---
import { t, type Locale } from '../i18n';
const { locale } = Astro.props as { locale: Locale };
const dict = t(locale);

const offers = [
  { key: 'car', image: '/images/bmw-e46-night-side', pos: 'center 62%', ...dict.partnerships.offers.car },
  { key: 'uniform', image: '/images/fans-supporters-portrait', pos: 'center', ...dict.partnerships.offers.uniform },
  { key: 'social', image: '/images/drift-action-pakelo-track', pos: 'center', ...dict.partnerships.offers.social },
  { key: 'paddock', image: '/images/team-paddock-group', pos: 'center', ...dict.partnerships.offers.paddock },
];
---
<section class="relative bg-[var(--color-bg)] py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mb-10 sm:mb-14">
      <h2 class="font-display text-3xl sm:text-5xl text-white">{dict.partnerships.offers_title}</h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-4 sm:gap-6">
      {offers.map((o, i) => (
        <article class="reveal group relative aspect-[16/10] overflow-hidden rounded-sm bg-[var(--color-bg-card)] border border-[var(--color-border)]" style={`transition-delay: ${i * 80}ms`}>
          <picture>
            <source srcset={`${o.image}.webp`} type="image/webp" />
            <img src={`${o.image}.jpg`} alt="" style={`object-position: ${o.pos};`} class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:opacity-85 group-hover:scale-105 transition-all duration-700" loading="lazy" decoding="async" />
          </picture>
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/45 to-black/5"></div>
          <div class="relative h-full flex flex-col justify-end p-6 sm:p-8">
            <div class="text-[10px] font-mono tracking-widest text-[var(--color-accent)]/70 mb-1.5">0{i + 1}</div>
            <h3 class="font-display text-xl sm:text-2xl text-white leading-tight">{o.title}</h3>
            <p class="mt-2 text-sm sm:text-base text-[var(--color-text)]/85 max-w-prose">{o.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
