---
import { t, type Locale } from '../i18n';
import { REACH } from '../data/site';

const { locale } = Astro.props as { locale: Locale };
const dict = t(locale);
const items = REACH.map((r) => {
  const label = (dict.reach.metrics as Record<string, string>)[r.key];
  const decimals = r.value % 1 === 0 ? 0 : 1;
  return { ...r, label, decimals };
});
---
<section id="reach" class="relative bg-[var(--color-bg)] py-20 sm:py-28 overflow-hidden">
  <div aria-hidden="true" class="absolute inset-0 -z-10 opacity-[0.04] bg-[radial-gradient(circle_at_50%_50%,var(--color-accent),transparent_60%)]"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mb-10 sm:mb-14 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-accent)] mb-4">{dict.reach.kicker}</p>
      <h2 class="font-display text-3xl sm:text-5xl lg:text-6xl leading-[0.95] text-white">{dict.reach.title}</h2>
      <p class="mt-5 max-w-2xl text-base text-[var(--color-text)]/80">{dict.reach.body}</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-5">
      {items.map((it, i) => (
        <div class="reveal bg-[var(--color-bg-elevated)] border border-[var(--color-border)] rounded-sm p-5 sm:p-6 hover:border-[var(--color-accent)] transition-colors" style={`transition-delay: ${i * 60}ms`}>
          <div class="flex items-baseline gap-1 font-display text-white">
            <span data-counter data-target={it.value} data-decimals={it.decimals} class="text-3xl sm:text-5xl tabular-nums">0</span>
            <span class="text-xl sm:text-3xl text-[var(--color-accent)]">{it.unit}</span>
          </div>
          <p class="mt-2 text-xs sm:text-sm text-[var(--color-text-muted)] uppercase tracking-wider">{it.label}</p>
        </div>
      ))}
    </div>

    <p class="mt-8 text-xs text-[var(--color-text-muted)] italic">{dict.reach.caveat}</p>
  </div>
</section>
