---
import { t, type Locale } from '../i18n';
const { locale } = Astro.props as { locale: Locale };
const dict = t(locale);
---
<section id="reel" class="relative bg-black py-16 sm:py-20 overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal relative aspect-video overflow-hidden rounded-sm border border-[var(--color-border)] bg-[var(--color-bg-elevated)]" data-reel>
      <video
        class="w-full h-full object-cover"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/video/chasing-extreme-poster.jpg"
        data-reel-video
      >
        <source src="/video/chasing-extreme.webm" type="video/webm" />
        <source src="/video/chasing-extreme.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent pointer-events-none"></div>
      <div class="absolute inset-x-0 bottom-0 p-5 sm:p-8 pointer-events-none">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-accent)] mb-2">{dict.reel.kicker}</p>
        <h2 class="font-display text-2xl sm:text-4xl lg:text-5xl leading-[0.95] text-white max-w-2xl">{dict.reel.title}</h2>
        <p class="mt-3 max-w-xl text-sm sm:text-base text-[var(--color-text)]/85">{dict.reel.body}</p>
      </div>

      <button
        type="button"
        data-reel-play
        class="hidden absolute inset-0 m-auto w-16 h-16 sm:w-20 sm:h-20 rounded-full bg-[var(--color-accent)] text-black items-center justify-center hover:scale-110 transition-transform"
        aria-label={dict.reel.play_label}
      >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7L8 5z"/></svg>
      </button>
    </div>
  </div>

  <script is:inline>
    const reel = document.querySelector('[data-reel]');
    if (reel) {
      const video = reel.querySelector('[data-reel-video]');
      const playBtn = reel.querySelector('[data-reel-play]');
      const prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReduce && video && playBtn) {
        video.removeAttribute('autoplay');
        video.pause();
        playBtn.classList.remove('hidden');
        playBtn.classList.add('flex');
        playBtn.addEventListener('click', () => {
          video.play();
          playBtn.classList.add('hidden');
        });
      }
    }
  </script>
</section>
