---
import { t, type Locale } from '../i18n';
import { SOCIALS, REACH } from '../data/site';
const { locale } = Astro.props as { locale: Locale };
const dict = t(locale);
const yt = SOCIALS.find((s) => s.key === 'youtube')!;
const ig = SOCIALS.find((s) => s.key === 'instagram')!;
const tt = SOCIALS.find((s) => s.key === 'tiktok')!;
const ytReach = REACH.find((r) => r.key === 'yt_subs')!;
const igReach = REACH.find((r) => r.key === 'ig_followers')!;
const ttReach = REACH.find((r) => r.key === 'tt_followers')!;
const dec = (n: number) => (n % 1 === 0 ? 0 : 1);

const cards = [
  {
    href: yt.url,
    label: dict.channel.metrics.yt_subs,
    handle: yt.handle,
    value: ytReach.value,
    unit: ytReach.unit,
    hover: 'hover:border-[var(--color-red)]',
    icon: 'yt',
  },
  {
    href: ig.url,
    label: dict.channel.metrics.ig_followers,
    handle: ig.handle,
    value: igReach.value,
    unit: igReach.unit,
    hover: 'hover:border-[var(--color-accent)]',
    icon: 'ig',
  },
  {
    href: tt.url,
    label: dict.channel.metrics.tt_followers,
    handle: tt.handle,
    value: ttReach.value,
    unit: ttReach.unit,
    hover: 'hover:border-white',
    icon: 'tt',
  },
];
---
<section id="channel" class="relative bg-[var(--color-bg)] py-20 sm:py-28 overflow-hidden">
  <div aria-hidden="true" class="absolute inset-0 -z-10 opacity-[0.05] bg-[radial-gradient(circle_at_30%_40%,var(--color-accent),transparent_55%)]"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
    <div class="lg:col-span-7 reveal">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-accent)] mb-4">{dict.channel.kicker}</p>
      <h2 class="font-display text-3xl sm:text-5xl lg:text-6xl leading-[0.95] text-white">{dict.channel.title}</h2>
      <p class="mt-5 max-w-xl text-base sm:text-lg text-[var(--color-text)]/85">{dict.channel.body}</p>
    </div>

    <div class="lg:col-span-5 reveal grid gap-4 sm:gap-5" style="transition-delay: 120ms">
      {cards.map((c, i) => (
        <a
          href={c.href}
          target="_blank"
          rel="noopener noreferrer"
          class={`group flex items-center justify-between gap-4 bg-[var(--color-bg-elevated)] border border-[var(--color-border)] ${c.hover} rounded-sm p-5 sm:p-6 transition-colors`}
        >
          <div>
            <div class="flex items-baseline gap-1 font-display text-white">
              <span data-counter data-target={c.value} data-decimals={dec(c.value)} class="text-3xl sm:text-4xl tabular-nums">0</span>
              <span class="text-xl sm:text-2xl text-[var(--color-accent)]">{c.unit}</span>
            </div>
            <p class="mt-1 text-xs text-[var(--color-text-muted)] uppercase tracking-wider">{c.label}</p>
            <p class="text-sm text-white mt-1">{c.handle}</p>
          </div>
          {c.icon === 'yt' && (
            <svg width="40" height="40" viewBox="0 0 24 24" class="text-[var(--color-red)] group-hover:scale-110 transition-transform" fill="currentColor" aria-hidden="true">
              <path d="M23 7.5s-.2-1.6-.9-2.3c-.8-.9-1.8-.9-2.2-1C16.3 4 12 4 12 4s-4.3 0-7.9.2c-.4 0-1.4.1-2.2 1C1.2 5.9 1 7.5 1 7.5S.8 9.4.8 11.3v1.4c0 1.9.2 3.8.2 3.8s.2 1.6.9 2.3c.8.9 1.9.9 2.4 1 1.7.2 7.6.2 7.6.2s4.3 0 7.9-.3c.4-.1 1.4-.1 2.2-1 .7-.7.9-2.3.9-2.3s.2-1.9.2-3.8v-1.4c0-1.9-.3-3.7-.3-3.7zM9.7 15.4V8.6l5.6 3.4-5.6 3.4z"/>
            </svg>
          )}
          {c.icon === 'ig' && (
            <svg width="36" height="36" viewBox="0 0 24 24" class="text-white group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
            </svg>
          )}
          {c.icon === 'tt' && (
            <svg width="36" height="36" viewBox="0 0 24 24" class="text-white group-hover:scale-110 transition-transform" fill="currentColor" aria-hidden="true">
              <path d="M16.5 2c.2 1.7 1.2 3 2.8 3.6.7.3 1.5.4 2.2.4v3.2c-1.6 0-3.2-.5-4.5-1.4v6.6c0 4-3.3 7.3-7.3 7.3S2.4 18.4 2.4 14.4c0-3.9 3.2-7.1 7.1-7.2v3.4c-2.1 0-3.8 1.7-3.8 3.8s1.7 3.9 3.9 3.9 3.9-1.7 3.9-3.9V2h2.9z"/>
            </svg>
          )}
        </a>
      ))}
    </div>
  </div>
</section>
