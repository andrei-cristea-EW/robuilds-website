---
import { t, type Locale } from '../i18n';
const { locale } = Astro.props as { locale: Locale };
const dict = t(locale);
---
<section class="relative isolate overflow-hidden bg-black pt-32 pb-20 sm:pt-40 sm:pb-28">
  <picture class="absolute inset-0 -z-10">
    <source srcset="/images/drift-panning-redrift-26.webp" type="image/webp" />
    <img src="/images/drift-panning-redrift-26.jpg" alt="" class="hero-zoom w-full h-full object-cover opacity-40" fetchpriority="high" decoding="async" />
  </picture>
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-black/40 via-black/60 to-[var(--color-bg)]"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-accent)] mb-5 flex items-center gap-3">
        <span class="inline-block w-8 h-px bg-[var(--color-accent)]"></span>
        {dict.partnerships.title}
      </p>
      <h1 class="font-display text-4xl sm:text-6xl lg:text-7xl leading-[0.92] text-white">{dict.partnerships.hero_title}</h1>
      <p class="mt-6 max-w-2xl text-base sm:text-lg text-[var(--color-text)]/85">{dict.partnerships.hero_body}</p>
    </div>
  </div>
</section>
