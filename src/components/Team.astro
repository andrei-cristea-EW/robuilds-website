---
import { t, type Locale } from '../i18n';
import { TEAM, RESULTS_ORDER } from '../data/site';
import fs from 'node:fs';
import path from 'node:path';

const { locale } = Astro.props as { locale: Locale };
const dict = t(locale);

const publicDir = path.resolve('./public');
const members = TEAM.map((m) => {
  const webpAbs = path.join(publicDir, m.photo.replace(/^\//, ''));
  const jpgAbs = path.join(publicDir, m.photoFallback.replace(/^\//, ''));
  const hasPhoto = fs.existsSync(webpAbs) || fs.existsSync(jpgAbs);
  const info = (dict.team.members as Record<string, { name: string; role: string }>)[m.key];
  return { ...m, hasPhoto, name: info.name, role: info.role };
});

const results = RESULTS_ORDER.map((k) => {
  const v = (dict.results.items as Record<string, { year: string; label: string }>)[k];
  return { key: k, ...v };
});
---
<section id="team" class="relative bg-[var(--color-bg)] py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mb-10 sm:mb-14 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-accent)] mb-4">{dict.team.kicker}</p>
      <h2 class="font-display text-3xl sm:text-5xl lg:text-6xl leading-[0.95] text-white sm:whitespace-nowrap">{dict.team.title}</h2>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 sm:gap-5">
      {members.map((m, i) => (
        <article class="reveal group relative aspect-[3/4] overflow-hidden rounded-sm bg-[var(--color-bg-card)] border border-[var(--color-border)]" style={`transition-delay: ${i * 80}ms`}>
          {m.hasPhoto ? (
            <picture>
              <source srcset={m.photo} type="image/webp" />
              <img src={m.photoFallback} alt={m.name} class="w-full h-full object-cover group-hover:scale-105 transition-all duration-700" loading="lazy" decoding="async" />
            </picture>
          ) : (
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="font-display text-7xl sm:text-9xl text-[var(--color-border)]">{m.name.charAt(0)}</span>
            </div>
          )}
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black via-black/70 to-transparent p-3 sm:p-4">
            <h3 class="font-display text-base sm:text-lg text-white leading-tight">{m.name}</h3>
            <p class="text-[10px] sm:text-xs uppercase tracking-wider text-[var(--color-accent)] mt-1">{m.role}</p>
          </div>
        </article>
      ))}
    </div>

    <div id="results" class="reveal mt-16 sm:mt-24 mb-8 sm:mb-10 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-accent)] mb-4">{dict.results.kicker}</p>
      <h2 class="font-display text-3xl sm:text-5xl lg:text-6xl leading-[0.95] text-white">{dict.results.title}</h2>
    </div>

    <ol class="relative grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
      {results.map((it, i) => {
        const isCurrent = it.key === 'y2026';
        const isFuture = it.key === 'future';
        return (
          <li
            class={`reveal relative bg-[var(--color-bg-card)] rounded-sm p-6 sm:p-8 overflow-hidden group ${isFuture ? 'border-2 border-dashed border-[var(--color-accent)]/50' : 'border border-[var(--color-border)]'}`}
            style={`transition-delay: ${i * 100}ms`}
          >
            <div class={`absolute top-0 left-0 h-1 w-full ${isCurrent ? 'bg-[var(--color-accent)]' : isFuture ? 'bg-transparent' : 'bg-[var(--color-border)]'}`}></div>
            <div class={`font-display leading-[0.95] ${isFuture ? 'text-xl sm:text-2xl text-[var(--color-accent)]' : 'text-5xl sm:text-7xl text-white/90'}`}>
              {it.year}
            </div>
            <p class={`mt-3 text-sm sm:text-base ${isCurrent ? 'text-[var(--color-accent)]' : 'text-[var(--color-text-muted)]'}`}>{it.label}</p>
            {isCurrent && (
              <span class="absolute top-4 right-4 text-[10px] uppercase tracking-widest font-semibold bg-[var(--color-accent)] text-black px-2 py-0.5 rounded-sm">
                {locale === 'ro' ? 'În curs' : 'Live'}
              </span>
            )}
            {isFuture && (
              <span class="absolute top-4 right-4 text-[10px] uppercase tracking-widest font-semibold border border-[var(--color-accent)]/60 text-[var(--color-accent)] px-2 py-0.5 rounded-sm">
                {locale === 'ro' ? 'Țintă' : 'Goal'}
              </span>
            )}
          </li>
        );
      })}
    </ol>
  </div>
</section>
