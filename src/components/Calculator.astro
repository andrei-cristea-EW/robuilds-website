---
import { t, type Locale } from '../i18n';

const { locale } = Astro.props as { locale: Locale };
const dict = t(locale);
const c = dict.calculator;

// Gearbox presets (ratios only — reverse & final drive ignored). 5-speed
// boxes leave gear 6 blank. The first entry is the editable "Custom" default.
const P = c.presets;
const PRESETS = [
  { label: `ZF S5D (310Z/320Z) · ${P.p5}`, gears: [4.21, 2.49, 1.67, 1.24, 1.0] },
  { label: `ZF GS5-39DZ · ${P.d5}`, gears: [5.24, 2.91, 1.81, 1.27, 1.0] },
  { label: `ZF GS6-37BZ · ${P.p6}`, gears: [4.35, 2.496, 1.665, 1.234, 1.0, 0.851] },
  { label: `ZF GS6-37DZ · ${P.d6}`, gears: [5.14, 2.83, 1.79, 1.26, 1.0, 0.83] },
  { label: `ZF GS6-53BZ · ${P.p6}`, gears: [4.055, 2.396, 1.582, 1.19, 1.0, 0.843] },
  { label: `ZF GS6-53DZ · ${P.d6}`, gears: [5.08, 2.804, 1.783, 1.26, 1.0, 0.835] },
  { label: `ZF GS6-45DZ · ${P.d6}`, gears: [4.11, 2.248, 1.403, 1.0, 0.802, 0.659] },
  { label: 'GearMotive H-pattern dog · Rally/Track', gears: [2.23, 1.71, 1.38, 1.16, 1.0] },
  { label: 'GearMotive H-pattern dog · Drift/Drag', gears: [2.73, 1.83, 1.42, 1.16, 1.0] },
  { label: 'GearMotive Sequential dog · Rally/Track', gears: [2.23, 1.71, 1.38, 1.16, 1.0] },
  { label: 'GearMotive Sequential dog · Drift/Drag', gears: [2.73, 1.83, 1.42, 1.16, 1.0] },
];

// Seeded defaults so the matrix is populated on first load (GS5-39DZ values,
// padded to 6 → gear 6 blank).
const DEFAULT_RATIOS = [5.24, 2.91, 1.81, 1.27, 1.0];
const DEFAULT_GEARS = [...DEFAULT_RATIOS, ...Array(6 - DEFAULT_RATIOS.length).fill('')];
const DEFAULT_DIFFS = [3.46, 3.9, 4.1]; // dynamic list

const inputClass =
  'w-full max-w-[9rem] rounded-sm bg-[var(--color-bg-elevated)] border border-[var(--color-border)] px-3 py-2.5 text-white tabular-nums focus:border-[var(--color-accent)] focus:outline-none transition-colors';
const presetBtnClass =
  'shrink-0 w-auto max-w-[12rem] truncate appearance-none cursor-pointer rounded-sm border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-center text-[var(--color-accent)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-black focus:border-[var(--color-accent)] focus:outline-none transition-colors';
const labelClass =
  'block text-xs font-medium uppercase tracking-wider text-[var(--color-text-muted)] mb-1.5';
---
<section id="calculator" data-calc class="relative bg-[var(--color-bg)] py-20 sm:py-28 overflow-hidden">
  <div aria-hidden="true" class="absolute inset-0 -z-10 opacity-[0.05] bg-[radial-gradient(circle_at_70%_30%,var(--color-accent),transparent_55%)]"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mb-10 sm:mb-14 max-w-3xl">
      <h1 class="font-display text-3xl sm:text-5xl lg:text-6xl leading-[0.95] text-white">{c.title}</h1>
      <p class="mt-5 max-w-2xl text-base sm:text-lg text-[var(--color-text)]/80">{c.body}</p>
    </div>

    <div class="grid lg:grid-cols-12 gap-6 lg:gap-8 items-start">
      <!-- Inputs -->
      <div class="reveal min-w-0 lg:col-span-5 bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-sm p-5 sm:p-7">
        <h2 class="font-display text-xl sm:text-2xl text-white mb-6">{c.inputs_title}</h2>

        <div class="divide-y divide-[var(--color-border)]">
          <!-- Engine & Tires -->
          <section class="pb-6">
            <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-3">{c.sections.engine_tires}</h3>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class={labelClass} for="calc-rpm">{c.labels.rpm}</label>
                <input id="calc-rpm" data-rpm type="number" inputmode="numeric" min="0" step="100" value="7000" class={inputClass} />
              </div>
              <div>
                <label class={labelClass} for="calc-width">{c.labels.width}</label>
                <input id="calc-width" data-width type="number" inputmode="numeric" min="0" step="5" value="265" class={inputClass} />
              </div>
              <div>
                <label class={labelClass} for="calc-aspect">{c.labels.aspect}</label>
                <input id="calc-aspect" data-aspect type="number" inputmode="numeric" min="0" step="1" value="35" class={inputClass} />
              </div>
              <div>
                <label class={labelClass} for="calc-rim">{c.labels.rim}</label>
                <input id="calc-rim" data-rim type="number" inputmode="decimal" min="0" step="0.5" value="18" class={inputClass} />
              </div>
            </div>
          </section>

          <!-- Gearbox (fixed 6) -->
          <section class="py-6">
            <div class="flex items-center justify-between gap-3 mb-3">
              <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)]">{c.sections.gearbox}</h3>
              <select data-preset aria-label={c.labels.load_preset} class={presetBtnClass}>
                <option value="" selected>{c.labels.load_preset}</option>
                {PRESETS.map((p, i) => (
                  <option value={i}>{p.label}</option>
                ))}
              </select>
            </div>

            <span class={labelClass}>{c.labels.gears}</span>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              {DEFAULT_GEARS.map((g, i) => (
                <div class="flex items-center gap-2">
                  <span class="w-7 shrink-0 text-sm font-display text-[var(--color-text-muted)]">{i + 1}</span>
                  <input data-gear-ratio type="number" inputmode="decimal" min="0" step="0.01" value={g} aria-label={`${c.labels.gear} ${i + 1}`} class={inputClass} />
                </div>
              ))}
            </div>
          </section>

          <!-- Differential (dynamic list) -->
          <section class="pt-6">
            <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-3">{c.sections.differential}</h3>
            <span class={labelClass}>{c.labels.final_drives}</span>
            <div data-diffs class="space-y-2.5">
              {DEFAULT_DIFFS.map((d) => (
                <div data-diff-row class="flex items-center gap-2.5">
                  <input data-diff-ratio type="number" inputmode="decimal" min="0" step="0.01" value={d} class={inputClass} />
                  <button type="button" data-remove-diff aria-label={c.remove_diff} class="shrink-0 w-9 h-9 inline-flex items-center justify-center rounded-sm border border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-[var(--color-red)] hover:text-[var(--color-red)] transition-colors">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </button>
                </div>
              ))}
            </div>
            <button type="button" data-add-diff class="mt-3 text-sm font-medium text-[var(--color-accent)] hover:text-white transition-colors">
              {c.add_diff}
            </button>
          </section>
        </div>
      </div>

      <!-- Results -->
      <div class="reveal min-w-0 lg:col-span-7 bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-sm p-5 sm:p-7" style="transition-delay: 120ms">
        <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 mb-1">
          <h2 class="font-display text-xl sm:text-2xl text-white">{c.results_title}</h2>
          <p data-readout class="text-sm text-[var(--color-text-muted)] tabular-nums"></p>
        </div>
        <p class="text-xs text-[var(--color-text-muted)] mb-5">{c.legend}</p>

        <div class="overflow-x-auto -mx-1 px-1">
          <table data-table class="w-full text-left border-collapse tabular-nums"></table>
        </div>

        <div class="mt-6 flex flex-col sm:flex-row sm:items-center gap-4">
          <button type="button" data-download class="inline-flex items-center justify-center gap-2 rounded-sm bg-[var(--color-accent)] px-5 py-3 text-sm font-semibold uppercase tracking-wider text-black hover:bg-white transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            {c.download}
          </button>
        </div>

        <p class="mt-6 text-xs text-[var(--color-text-muted)] italic leading-relaxed">{c.disclaimer}</p>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ T: c.table, TITLE: c.title, S: c.sections, PRESETS_G: PRESETS.map((p) => p.gears) }}>
  (() => {
    const section = document.querySelector('[data-calc]');
    if (!section) return;

    const $ = (sel) => section.querySelector(sel);
    const table = $('[data-table]');
    const readout = $('[data-readout]');
    const diffs = $('[data-diffs]');

    const num = (sel) => {
      const el = $(sel);
      const v = parseFloat(el && el.value);
      return Number.isFinite(v) ? v : NaN;
    };

    // Last computed state, reused by the PNG export.
    let lastMatrix = null;

    function recompute() {
      const rpm = num('[data-rpm]');
      const rim = num('[data-rim]');
      const width = num('[data-width]');
      const aspect = num('[data-aspect]');

      const diameter = rim * 25.4 + 2 * (width * (aspect / 100)); // mm
      const circ = Math.PI * diameter; // mm

      const tireStr = `${width || 0}/${aspect || 0} R${rim || 0}`;
      const tireFull = Number.isFinite(diameter) && diameter > 0 ? `${tireStr} · Ø${Math.round(diameter)} mm` : tireStr;
      readout.textContent = Number.isFinite(diameter) && diameter > 0 ? tireFull : '';

      const gears = [...section.querySelectorAll('[data-gear-ratio]')].map((el, i) => ({
        n: i + 1,
        ratio: parseFloat(el.value),
      }));
      const diffVals = [...diffs.querySelectorAll('[data-diff-ratio]')].map((el) => parseFloat(el.value));

      const speed = (gear, final) => {
        if (rpm > 0 && final > 0 && gear > 0 && circ > 0) {
          return (rpm / (gear * final)) * circ * 60 / 1e6;
        }
        return null;
      };

      // Build the table (header + body) from scratch.
      const headCells = [`<th class="sticky left-0 z-10 bg-[var(--color-bg-card)] py-3 pr-4"></th>`];
      gears.forEach((g) => {
        const r = g.ratio > 0 ? g.ratio.toFixed(2) : '—';
        headCells.push(
          `<th class="py-3 px-2 sm:px-4 text-center whitespace-nowrap">` +
            `<span class="block font-display text-lg sm:text-2xl text-white leading-none">${g.n}</span>` +
            `<span class="block text-xs sm:text-sm tabular-nums text-[var(--color-text-muted)] mt-1">${r}</span>` +
          `</th>`
        );
      });

      const bodyRows = diffVals.map((final, ri) => {
        const finalStr = final > 0 ? final.toFixed(2) : '—';
        const cells = gears.map((g) => {
          const v = speed(g.ratio, final);
          const txt = v === null ? '—' : v.toFixed(1);
          return `<td class="py-3 px-2 sm:px-4 text-right tabular-nums text-sm sm:text-lg text-white">${txt}</td>`;
        });
        const zebra = ri % 2 === 1 ? ' bg-[var(--color-bg-elevated)]' : ' bg-[var(--color-bg-card)]';
        return (
          `<tr class="border-t border-[var(--color-border)]${zebra}">` +
            `<td class="sticky left-0 z-10${zebra} py-3 pr-2 sm:pr-4 text-left font-display text-lg sm:text-2xl text-[var(--color-accent)] whitespace-nowrap">${finalStr}</td>` +
            cells.join('') +
          `</tr>`
        );
      });

      table.innerHTML =
        `<thead><tr class="border-b border-[var(--color-border)]">${headCells.join('')}</tr></thead>` +
        `<tbody>${bodyRows.join('')}</tbody>`;

      // Snapshot for the PNG.
      lastMatrix = {
        rpm: Number.isFinite(rpm) ? String(rpm) : '–',
        tire: tireFull,
        gears: gears.map((g) => ({ n: g.n, ratio: g.ratio > 0 ? g.ratio.toFixed(2) : '—' })),
        diffs: diffVals.map((final) => ({
          ratio: final > 0 ? final.toFixed(2) : '—',
          cells: gears.map((g) => {
            const v = speed(g.ratio, final);
            return v === null ? '—' : v.toFixed(1);
          }),
        })),
      };
    }

    function addDiff() {
      const rows = diffs.querySelectorAll('[data-diff-row]');
      const last = rows[rows.length - 1];
      const row = last ? last.cloneNode(true) : null;
      if (!row) return;
      const inp = row.querySelector('[data-diff-ratio]');
      if (inp) inp.value = '';
      diffs.appendChild(row);
      recompute();
    }

    function removeDiff(row) {
      const rows = diffs.querySelectorAll('[data-diff-row]');
      if (rows.length <= 1) return; // keep at least one
      row.remove();
      recompute();
    }

    // Gearbox preset loader (fills the 6 gear inputs; 5-speed clears gear 6).
    const presetEl = $('[data-preset]');
    function loadPreset(i) {
      const arr = PRESETS_G[i];
      if (!arr) return;
      const inputs = [...section.querySelectorAll('[data-gear-ratio]')];
      inputs.forEach((inp, idx) => {
        inp.value = arr[idx] != null ? arr[idx] : '';
        // Restart the flash and stagger it across the fields.
        inp.classList.remove('field-flash');
        inp.style.animationDelay = '';
        void inp.offsetWidth; // force reflow so the animation re-triggers
        inp.style.animationDelay = idx * 55 + 'ms';
        inp.classList.add('field-flash');
        inp.addEventListener('animationend', () => {
          inp.classList.remove('field-flash');
          inp.style.animationDelay = '';
        }, { once: true });
      });
      recompute();
    }
    if (presetEl) presetEl.addEventListener('change', () => {
      const i = parseInt(presetEl.value, 10);
      if (!Number.isNaN(i)) loadPreset(i);
      presetEl.value = ''; // reset so the control always reads "Load Preset"
    });

    // Live updates (event-delegated so added rows work too).
    section.addEventListener('input', recompute);
    section.addEventListener('click', (e) => {
      if (e.target.closest('[data-add-diff]')) { addDiff(); return; }
      const rm = e.target.closest('[data-remove-diff]');
      if (rm) { removeDiff(rm.closest('[data-diff-row]')); return; }
      if (e.target.closest('[data-download]')) { downloadImage(); return; }
    });

    // ---- PNG export ----------------------------------------------------
    async function downloadImage() {
      recompute();
      try { if (document.fonts && document.fonts.ready) await document.fonts.ready; } catch (_) {}
      const m = lastMatrix;
      if (!m) return;

      // Brand wordmark (same-origin PNG; falls back to text if it can't load).
      const logo = new Image();
      logo.src = '/logos/robuilds/wordmark-white.png';
      let logoOk = false;
      try { await logo.decode(); logoOk = logo.naturalWidth > 0; } catch (_) { logoOk = false; }

      const scale = 2;
      const padX = 48;
      const titleY = 52;
      const specTop = 88;
      const specGap = 28;
      const logoCy = 75; // vertical centre of the title+spec block (top-right logo)
      const tableTop = specTop + 2 * specGap + 16;
      const headRowH = 56;
      const rowH = 48;
      const footH = 60;
      const firstColW = 104;
      const cellW = 92;
      const W = padX * 2 + firstColW + m.gears.length * cellW;
      const H = tableTop + headRowH + m.diffs.length * rowH + footH;

      const canvas = document.createElement('canvas');
      canvas.width = W * scale;
      canvas.height = H * scale;
      const ctx = canvas.getContext('2d');
      ctx.scale(scale, scale);

      const BG = '#0A0B0D', CARD = '#15171B', ACCENT = '#57E223';
      const WHITE = '#F5F5F4', MUTED = '#9CA0A6', BORDER = '#25282E';
      const display = '"Anton", "Impact", sans-serif';
      const sans = '"Inter", system-ui, sans-serif';

      ctx.fillStyle = BG;
      ctx.fillRect(0, 0, W, H);

      // Header: title + spec on the left, logo top-right (inline, compact)
      ctx.textBaseline = 'alphabetic';
      ctx.fillStyle = WHITE;
      ctx.font = `24px ${display}`;
      ctx.fillText(TITLE, padX, titleY);
      ctx.fillStyle = ACCENT;
      ctx.fillRect(padX, titleY + 12, 56, 3);

      if (logoOk) {
        const logoH = 60;
        const logoW = logoH * (logo.naturalWidth / logo.naturalHeight);
        ctx.drawImage(logo, W - padX - logoW, logoCy - logoH / 2, logoW, logoH);
      } else {
        ctx.fillStyle = WHITE;
        ctx.font = `18px ${display}`;
        ctx.textAlign = 'right';
        ctx.fillText('RO BUILDS MOTORSPORT', W - padX, logoCy + 6);
        ctx.textAlign = 'left';
      }

      // Spec block (Engine + Tires; gearbox = columns, diffs = rows)
      const drawKV = (label, value, y) => {
        ctx.font = `12px ${sans}`;
        ctx.fillStyle = MUTED;
        const lab = label.toUpperCase();
        ctx.fillText(lab, padX, y);
        const lw = ctx.measureText(lab).width;
        ctx.font = `15px ${sans}`;
        ctx.fillStyle = WHITE;
        ctx.fillText(value, padX + lw + 14, y);
      };
      drawKV(S.engine, `${m.rpm} RPM`, specTop);
      drawKV(S.tires, m.tire, specTop + specGap);

      // Column geometry: first column left-aligned, gear columns right-aligned.
      const colRight = (gi) => padX + firstColW + gi * cellW + cellW - 12; // right edge of gear col gi
      const colCenter = (gi) => padX + firstColW + gi * cellW + cellW / 2; // horizontal centre of gear col gi
      const right = (txt, x, y) => { ctx.textAlign = 'right'; ctx.fillText(txt, x, y); ctx.textAlign = 'left'; };
      const center = (txt, x, y) => { ctx.textAlign = 'center'; ctx.fillText(txt, x, y); ctx.textAlign = 'left'; };

      // Header row
      let y = tableTop;
      m.gears.forEach((g, gi) => {
        ctx.fillStyle = WHITE;
        ctx.font = `24px ${display}`;
        center(`${g.n}`, colCenter(gi), y + 14);
        ctx.fillStyle = MUTED;
        ctx.font = `12px ${sans}`;
        center(g.ratio, colCenter(gi), y + 30);
      });
      ctx.strokeStyle = BORDER;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(padX, y + headRowH - 10);
      ctx.lineTo(W - padX, y + headRowH - 10);
      ctx.stroke();

      // Body rows
      y = tableTop + headRowH;
      m.diffs.forEach((row, ri) => {
        const rowY = y + ri * rowH;
        if (ri % 2 === 1) {
          ctx.fillStyle = CARD;
          ctx.fillRect(padX - 12, rowY - 6, W - padX * 2 + 24, rowH);
        }
        const tY = rowY + rowH / 2 + 5;
        ctx.fillStyle = ACCENT;
        ctx.font = `20px ${display}`;
        ctx.fillText(row.ratio, padX, tY);
        ctx.fillStyle = WHITE;
        ctx.font = `16px ${sans}`;
        row.cells.forEach((cell, gi) => right(cell, colRight(gi), tY));
      });

      // Footer
      ctx.fillStyle = MUTED;
      ctx.font = `13px ${sans}`;
      ctx.fillText('robuilds.ro', padX, H - 24);

      canvas.toBlob((blob) => {
        if (!blob) return;
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'robuilds-gear-speeds.png';
        document.body.appendChild(a);
        a.click();
        a.remove();
        setTimeout(() => URL.revokeObjectURL(url), 1000);
      }, 'image/png');
    }

    recompute();
  })();
</script>
