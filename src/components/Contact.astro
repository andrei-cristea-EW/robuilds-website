---
import { t, type Locale } from '../i18n';
import { SITE } from '../data/site';
const { locale } = Astro.props as { locale: Locale };
const dict = t(locale);

const channels = [
  {
    label: dict.contact.channels.email_label,
    value: SITE.email,
    href: `mailto:${SITE.email}`,
    note: '',
    icon: 'mail',
    accent: 'border-[var(--color-border)] hover:border-[var(--color-accent)]',
  },
  {
    label: dict.contact.channels.whatsapp_label,
    value: SITE.phone,
    href: SITE.whatsappUrl,
    note: dict.contact.channels.whatsapp_note,
    icon: 'whatsapp',
    accent: 'border-[var(--color-border)] hover:border-[#25D366]',
    external: true,
  },
  {
    label: dict.contact.channels.phone_label,
    value: SITE.phone,
    href: `tel:${SITE.phoneDigits}`,
    note: '',
    icon: 'phone',
    accent: 'border-[var(--color-border)] hover:border-[var(--color-accent)]',
  },
];
---
<section id="partnership" class="relative bg-[var(--color-bg)] py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mb-10 sm:mb-12 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-accent)] mb-4">{dict.contact.kicker}</p>
      <h2 class="font-display text-3xl sm:text-5xl lg:text-6xl leading-[0.95] text-white">{dict.contact.title}</h2>
      <p class="mt-5 text-base sm:text-lg text-[var(--color-text)]/85 lg:whitespace-nowrap lg:max-w-none">{dict.contact.body}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-5">
      {channels.map((c, i) => (
        <a
          href={c.href}
          target={c.external ? '_blank' : undefined}
          rel={c.external ? 'noopener noreferrer' : undefined}
          class={`reveal group bg-[var(--color-bg-elevated)] border ${c.accent} rounded-sm p-6 sm:p-8 flex flex-col transition-colors`}
          style={`transition-delay: ${i * 80}ms`}
        >
          <div class="mb-5 w-12 h-12 flex items-center justify-center bg-[var(--color-bg-card)] rounded-sm text-[var(--color-accent)] group-hover:scale-110 transition-transform">
            {c.icon === 'mail' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="1"/>
                <path d="M3 7l9 6 9-6"/>
              </svg>
            )}
            {c.icon === 'whatsapp' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.5 14.4c-.3-.1-1.7-.8-1.9-.9-.3-.1-.5-.1-.7.1-.2.3-.8.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.2 5 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.2-1.4-.1-.1-.3-.2-.6-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.1-1.3c1.4.8 3.1 1.2 4.9 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z"/>
              </svg>
            )}
            {c.icon === 'phone' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" aria-hidden="true">
                <path d="M5 4h4l2 5-3 2c1 2.5 3 4.5 5.5 5.5l2-3 5 2v4c0 .5-.5 1-1 1C9 20 4 15 4 5c0-.5.5-1 1-1z"/>
              </svg>
            )}
          </div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-text-muted)] mb-2">{c.label}</p>
          <p class="font-display text-lg sm:text-xl text-white break-all">{c.value}</p>
          {c.note && <p class="mt-2 text-sm text-[var(--color-text-muted)]">{c.note}</p>}
          <span class="mt-auto pt-4 inline-flex items-center text-sm font-semibold text-[var(--color-accent)] group-hover:gap-2 transition-all">
            {locale === 'ro' ? 'Deschide' : 'Open'} <span class="ml-1.5 group-hover:ml-2 transition-all">→</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
