---
import { t, type Locale } from '../i18n';
import { SOCIALS } from '../data/site';
const { locale } = Astro.props as { locale: Locale };
const dict = t(locale);
const yt = SOCIALS.find((s) => s.key === 'youtube')!;
const ig = SOCIALS.find((s) => s.key === 'instagram')!;
const tt = SOCIALS.find((s) => s.key === 'tiktok')!;

const slides = [
  { webp: '/images/drift-cone-hit-smoke.webp', jpg: '/images/drift-cone-hit-smoke.jpg', pos: 'center' },
  { webp: '/images/drift-pakelo-street-smoke.webp', jpg: '/images/drift-pakelo-street-smoke.jpg', pos: 'center 40%' },
  { webp: '/images/drift-panning-redrift-26.webp', jpg: '/images/drift-panning-redrift-26.jpg', pos: 'center' },
  { webp: '/images/drift-action-pakelo-track.webp', jpg: '/images/drift-action-pakelo-track.jpg', pos: 'center' },
  { webp: '/images/bmw-e46-night-side.webp', jpg: '/images/bmw-e46-night-side.jpg', pos: 'center 72%' },
];
---
<section id="hero" class="relative isolate min-h-[100svh] flex flex-col justify-end overflow-hidden bg-black">
  <div class="hero-carousel -z-10" aria-hidden="true">
    {slides.map((s, i) => (
      <div class="hero-slide">
        <picture>
          <source srcset={s.webp} type="image/webp" />
          <img
            src={s.jpg}
            alt=""
            style={`object-position: ${s.pos};`}
            fetchpriority={i === 0 ? 'high' : 'auto'}
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </picture>
      </div>
    ))}
  </div>
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-black/40 via-black/30 to-[var(--color-bg)]"></div>
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,transparent_30%,rgba(0,0,0,0.6))]"></div>

  <div class="relative mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 pt-32 pb-20 sm:pb-28">
    <div class="reveal max-w-4xl">
      <p class="text-xs sm:text-sm font-semibold uppercase tracking-[0.3em] text-[var(--color-accent)] mb-5">
        {dict.hero.eyebrow}
      </p>
      <h1 class="leading-[0.85] tracking-tight text-white">
        <span class="font-brand block whitespace-nowrap text-[clamp(2.5rem,10vw,8rem)]">{dict.hero.title_1}</span>
        <span class="font-brand block whitespace-nowrap text-[clamp(2.5rem,10vw,8rem)] text-[var(--color-accent)]">{dict.hero.title_2}</span>
      </h1>
      <p class="mt-6 max-w-xl text-base sm:text-lg text-[var(--color-text)]/85">{dict.hero.tagline}</p>
      <div class="mt-8 flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4">
        <a href="#support" class="inline-flex items-center justify-center min-w-[15rem] px-6 py-3 text-sm font-semibold tracking-wide uppercase bg-[var(--color-accent)] text-black hover:bg-white transition-colors rounded-sm">
          {dict.hero.cta_primary}
        </a>
        <div class="flex items-stretch gap-3 sm:gap-4 min-w-[15rem]">
          <a href={yt.url} target="_blank" rel="noopener noreferrer" aria-label={yt.label} class="flex-1 inline-flex items-center justify-center px-4 py-3 border border-white/30 text-white hover:bg-[#FF0000]/15 hover:border-[#FF0000] hover:text-[#FF0000] transition-colors rounded-sm">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23 7.5s-.2-1.6-.9-2.3c-.8-.9-1.8-.9-2.2-1C16.3 4 12 4 12 4s-4.3 0-7.9.2c-.4 0-1.4.1-2.2 1C1.2 5.9 1 7.5 1 7.5S.8 9.4.8 11.3v1.4c0 1.9.2 3.8.2 3.8s.2 1.6.9 2.3c.8.9 1.9.9 2.4 1 1.7.2 7.6.2 7.6.2s4.3 0 7.9-.3c.4-.1 1.4-.1 2.2-1 .7-.7.9-2.3.9-2.3s.2-1.9.2-3.8v-1.4c0-1.9-.3-3.7-.3-3.7zM9.7 15.4V8.6l5.6 3.4-5.6 3.4z"/></svg>
          </a>
          <a href={ig.url} target="_blank" rel="noopener noreferrer" aria-label={ig.label} class="flex-1 inline-flex items-center justify-center px-4 py-3 border border-white/30 text-white hover:bg-[#E1306C]/15 hover:border-[#E1306C] hover:text-[#E1306C] transition-colors rounded-sm">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
            </svg>
          </a>
          <a href={tt.url} target="_blank" rel="noopener noreferrer" aria-label={tt.label} class="flex-1 inline-flex items-center justify-center px-4 py-3 border border-white/30 text-white hover:bg-[#25F4EE]/15 hover:border-[#25F4EE] hover:text-[#25F4EE] transition-colors rounded-sm">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16.5 2c.2 1.7 1.2 3 2.8 3.6.7.3 1.5.4 2.2.4v3.2c-1.6 0-3.2-.5-4.5-1.4v6.6c0 4-3.3 7.3-7.3 7.3S2.4 18.4 2.4 14.4c0-3.9 3.2-7.1 7.1-7.2v3.4c-2.1 0-3.8 1.7-3.8 3.8s1.7 3.9 3.9 3.9 3.9-1.7 3.9-3.9V2h2.9z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <a href="#channel" aria-label={locale === 'ro' ? 'Derulează' : 'Scroll'} class="hero-scroll absolute bottom-6 left-1/2 -translate-x-1/2 hidden sm:flex flex-col items-center gap-2 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
    <span class="text-xs uppercase tracking-widest">{locale === 'ro' ? 'Derulează' : 'Scroll'}</span>
    <svg width="18" height="22" viewBox="0 0 18 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M9 3v14" />
      <path d="M3 12l6 6 6-6" />
    </svg>
  </a>
</section>
