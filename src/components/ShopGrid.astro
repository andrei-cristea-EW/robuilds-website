---
import { t, localePath, type Locale } from '../i18n';
import { PRODUCTS, CATEGORIES, productName } from '../data/products';

const { locale } = Astro.props as { locale: Locale };
const dict = t(locale);

const fmt = (n: number) => new Intl.NumberFormat(locale === 'ro' ? 'ro-RO' : 'en-US').format(n);

const groups = CATEGORIES
  .map((c) => ({ cat: c, items: PRODUCTS.filter((p) => p.category === c.key) }))
  .filter((g) => g.items.length > 0);
---
<section class="relative bg-[var(--color-bg)] py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    {groups.map((g) => (
      <div class="mb-16 sm:mb-20 last:mb-0">
        <div class="reveal mb-6 sm:mb-8 max-w-2xl">
          <h2 class="font-display text-2xl sm:text-4xl text-white leading-tight">{g.cat.title[locale]}</h2>
          <p class="mt-3 text-sm sm:text-base text-[var(--color-text-muted)]">{g.cat.blurb[locale]}</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
          {g.items.map((p, i) => {
            const sold = p.status === 'sold_out';
            return (
              <a href={localePath(locale, `shop/${p.slug}`)} class="reveal group flex flex-col h-full bg-[var(--color-bg-elevated)] border border-[var(--color-border)] hover:border-[var(--color-accent)] rounded-sm overflow-hidden transition-colors" style={`transition-delay: ${i * 60}ms`}>
                <div class="relative aspect-[4/3] overflow-hidden bg-black">
                  <picture>
                    <source srcset={`${p.images[0]}.webp`} type="image/webp" />
                    <img src={`${p.images[0]}.jpg`} alt={productName(p, locale)} class={`w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 ${sold ? 'grayscale opacity-60' : ''}`} loading="lazy" decoding="async" />
                  </picture>
                  {sold && (
                    <span class="absolute top-3 left-3 text-[10px] font-semibold uppercase tracking-widest bg-[var(--color-red)] text-white px-2 py-1 rounded-sm">{dict.shop.sold_out}</span>
                  )}
                </div>
                <div class="p-5 flex flex-col flex-1">
                  <h3 class="font-display text-xl sm:text-2xl text-white leading-tight">{productName(p, locale)}</h3>
                  <p class="mt-2 text-sm text-[var(--color-text-muted)] line-clamp-2">{p.blurb[locale]}</p>
                  <div class="mt-auto pt-4 flex items-baseline gap-1.5">
                    {p.price != null ? (
                      <>
                        {p.priceFrom && <span class="text-xs uppercase tracking-wider text-[var(--color-text-muted)]">{dict.shop.from}</span>}
                        <span class="font-display text-2xl sm:text-3xl text-[var(--color-accent)] tabular-nums">{fmt(p.price)}</span>
                        <span class="text-sm uppercase tracking-wider text-[var(--color-text-muted)]">{dict.shop.currency}</span>
                      </>
                    ) : (
                      <span class="font-display text-xl text-[var(--color-accent)]">{dict.shop.price_on_request}</span>
                    )}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    ))}
  </div>
</section>
