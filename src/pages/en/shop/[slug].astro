---
import Base from '../../../layouts/Base.astro';
import Contact from '../../../components/Contact.astro';
import { t, localePath } from '../../../i18n';
import { PRODUCTS } from '../../../data/products';
import { SITE } from '../../../data/site';

export function getStaticPaths() {
  return PRODUCTS.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const locale = 'en' as const;
const dict = t(locale);
const sold = product.status === 'sold_out';
const fmt = (n: number) => new Intl.NumberFormat('en-US').format(n);
const heroWebp = product.images[0].endsWith('.webp') ? product.images[0] : `${product.images[0]}.webp`;
const heroJpg = heroWebp.replace(/\.webp$/, '.jpg');
const waMsg = `Hi, I'm interested in "${product.name}".`;
const waHref = `${SITE.whatsappUrl}?text=${encodeURIComponent(waMsg)}`;
---
<Base locale={locale} pageKey="product" titleOverride={`${product.name} · ${dict.shop.title}`}>
  <section class="relative bg-[var(--color-bg)] pt-28 sm:pt-32 pb-20 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <a href={localePath(locale, 'shop')} class="reveal inline-flex items-center text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors mb-8">
        {dict.shop.back}
      </a>
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-14 items-start">
        <figure class="reveal relative aspect-[4/3] lg:aspect-square overflow-hidden rounded-sm bg-[var(--color-bg-elevated)] border border-[var(--color-border)]">
          <picture>
            <source srcset={heroWebp} type="image/webp" />
            <img src={heroJpg} alt={product.name} class={`w-full h-full object-cover ${sold ? 'grayscale opacity-70' : ''}`} loading="eager" decoding="async" />
          </picture>
          {sold && (
            <span class="absolute top-4 left-4 text-xs font-semibold uppercase tracking-widest bg-[var(--color-red)] text-white px-3 py-1 rounded-sm">{dict.shop.sold_out}</span>
          )}
        </figure>

        <div class="reveal" style="transition-delay: 100ms">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-accent)] mb-3">{dict.shop.product_label}</p>
          <h1 class="font-display text-3xl sm:text-5xl text-white leading-tight">{product.name}</h1>
          <p class="mt-5 text-base text-[var(--color-text)]/85">{product.blurb[locale]}</p>

          <div class="mt-8 flex items-baseline gap-2">
            {product.priceFrom && <span class="text-sm uppercase tracking-wider text-[var(--color-text-muted)]">{dict.shop.from}</span>}
            <span class="font-display text-4xl sm:text-5xl text-[var(--color-accent)] tabular-nums">{fmt(product.price)}</span>
            <span class="text-base uppercase tracking-wider text-[var(--color-text-muted)]">{dict.shop.currency}</span>
          </div>

          <a href={waHref} target="_blank" rel="noopener noreferrer" class="mt-8 inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold tracking-wide uppercase bg-[var(--color-accent)] text-black hover:bg-white transition-colors rounded-sm">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-1.9-.9-.3-.1-.5-.1-.7.1-.2.3-.8.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.2 5 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.2-1.4-.1-.1-.3-.2-.6-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.1-1.3c1.4.8 3.1 1.2 4.9 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg>
            {dict.shop.order_cta}
          </a>
        </div>
      </div>
    </div>
  </section>

  <Contact locale={locale} />
</Base>
