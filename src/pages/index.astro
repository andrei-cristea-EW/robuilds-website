---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import PartnerMarquee from '../components/PartnerMarquee.astro';
import Channel from '../components/Channel.astro';
import About from '../components/About.astro';
import Car from '../components/Car.astro';
import Team from '../components/Team.astro';
import Reach from '../components/Reach.astro';
import Community from '../components/Community.astro';
import Support from '../components/Support.astro';
import Contact from '../components/Contact.astro';
import { SOCIALS } from '../data/site';

const locale = 'ro' as const;
const yt = SOCIALS.find((s) => s.key === 'youtube')!;
const ig = SOCIALS.find((s) => s.key === 'instagram')!;
const tt = SOCIALS.find((s) => s.key === 'tiktok')!;
---
<Base locale={locale} pageKey="home">
  <Hero locale={locale} />
  <PartnerMarquee />
  <Channel locale={locale} />
  <About locale={locale} />
  <Car locale={locale} />
  <Team locale={locale} />
  <Reach locale={locale} />
  <Community locale={locale} />
  <Support locale={locale} />
  <Contact locale={locale} />

  <div class="lg:hidden fixed bottom-0 inset-x-0 z-30 px-3 pt-2 pb-[calc(0.75rem+env(safe-area-inset-bottom))] bg-gradient-to-t from-black via-black to-transparent" data-bottom-cta>
    <div class="flex gap-2">
      <a href={yt.url} target="_blank" rel="noopener noreferrer" aria-label={yt.label} class="flex-1 inline-flex items-center justify-center py-3 border border-white/30 text-white rounded-sm transition-colors hover:bg-[#FF0000]/15 hover:border-[#FF0000] hover:text-[#FF0000]">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23 7.5s-.2-1.6-.9-2.3c-.8-.9-1.8-.9-2.2-1C16.3 4 12 4 12 4s-4.3 0-7.9.2c-.4 0-1.4.1-2.2 1C1.2 5.9 1 7.5 1 7.5S.8 9.4.8 11.3v1.4c0 1.9.2 3.8.2 3.8s.2 1.6.9 2.3c.8.9 1.9.9 2.4 1 1.7.2 7.6.2 7.6.2s4.3 0 7.9-.3c.4-.1 1.4-.1 2.2-1 .7-.7.9-2.3.9-2.3s.2-1.9.2-3.8v-1.4c0-1.9-.3-3.7-.3-3.7zM9.7 15.4V8.6l5.6 3.4-5.6 3.4z"/></svg>
      </a>
      <a href={ig.url} target="_blank" rel="noopener noreferrer" aria-label={ig.label} class="flex-1 inline-flex items-center justify-center py-3 border border-white/30 text-white rounded-sm transition-colors hover:bg-[#E1306C]/15 hover:border-[#E1306C] hover:text-[#E1306C]">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
      </a>
      <a href={tt.url} target="_blank" rel="noopener noreferrer" aria-label={tt.label} class="flex-1 inline-flex items-center justify-center py-3 border border-white/30 text-white rounded-sm transition-colors hover:bg-[#25F4EE]/15 hover:border-[#25F4EE] hover:text-[#25F4EE]">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16.5 2c.2 1.7 1.2 3 2.8 3.6.7.3 1.5.4 2.2.4v3.2c-1.6 0-3.2-.5-4.5-1.4v6.6c0 4-3.3 7.3-7.3 7.3S2.4 18.4 2.4 14.4c0-3.9 3.2-7.1 7.1-7.2v3.4c-2.1 0-3.8 1.7-3.8 3.8s1.7 3.9 3.9 3.9 3.9-1.7 3.9-3.9V2h2.9z"/></svg>
      </a>
      <a href="/shop" class="flex-1 inline-flex items-center justify-center px-4 py-3 text-xs font-semibold tracking-wide uppercase bg-[var(--color-accent)] text-black rounded-sm">Shop</a>
    </div>
  </div>

  <script is:inline>
    const cta = document.querySelector('[data-bottom-cta]');
    if (cta) {
      const onScroll = () => {
        if (window.scrollY > window.innerHeight * 0.6) cta.classList.remove('translate-y-full');
        else cta.classList.add('translate-y-full');
      };
      cta.classList.add('transition-transform', 'duration-300', 'translate-y-full');
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  </script>
</Base>
